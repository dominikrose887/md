{
  "name": "md-studio",
  "description": "GitHub-like Markdown desktop editor and viewer",
  "author": "Rose",
  "private": true,
  "version": "1.4.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "build:installer": "npm run build && electron-builder --win nsis --x64",
    "build:portable": "npm run build && electron-builder --win portable --x64",
    "build:release": "npm run build && electron-builder --win nsis portable --x64",
    "release:github": "powershell -ExecutionPolicy Bypass -File ./build-github-release.ps1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-slot": "1.1.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "katex": "^0.16.45",
    "lucide-react": "0.487.0",
    "radix": "^0.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "2.1.7",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.1.0",
    "tailwindcss": "4.1.12",
    "vite": "6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.rose.mdstudio",
    "productName": "MD Studio",
    "asar": true,
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown file",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown file",
        "role": "Editor"
      },
      {
        "ext": "mdown",
        "name": "Markdown Document",
        "description": "Markdown file",
        "role": "Editor"
      }
    ]
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
